# OpenAI API key for email classification and response generation
OPENAI_API_KEY=sk-your-openai-api-key

# Path to Gmail OAuth2 credentials JSON file
GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json

# Airtable API key and base ID for logging classifications
AIRTABLE_API_KEY=pat-your-airtable-api-key
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Application settings
APP_ENV=development
LOG_LEVEL=INFO
PORT=8000
