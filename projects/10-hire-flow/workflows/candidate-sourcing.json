      "main": [
        [{ "node": "Score Candidate (OpenAI)", "type": "main", "index": 0 }],
        [{ "node": "Loop Over Jobs", "type": "main", "index": 0 }]
      ]
    },
    "Score Candidate (OpenAI)": {
      "main": [
        [{ "node": "Merge Candidate + AI Score", "type": "main", "index": 0 }]
      ]
    },
    "Merge Candidate + AI Score": {
      "main": [
        [{ "node": "Score >= 60?", "type": "main", "index": 0 }]
      ]
    },
    "Score >= 60?": {
