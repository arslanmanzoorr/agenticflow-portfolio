    {
      "id": "aggregate-results",
      "name": "Aggregate Sync Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2140, 300],
      "parameters": {
        "jsCode": "const allItems = $input.all();\n\nconst summary = {\n  total_processed: allItems.length,\n  created_in_sheets: 0,\n  updated_in_sheets: 0,\n  created_in_airtable: 0,\n  updated_in_airtable: 0,\n  conflicts_detected: 0,\n  errors: 0,\n  sync_timestamp: new Date().toISOString()\n};\n\nfor (const item of allItems) {\n  const d = item.json;\n  if (d.sync_action === 'create' && d.sync_direction === 'airtable_to_sheets') summary.created_in_sheets++;\n  if (d.sync_action === 'update' && d.sync_direction === 'airtable_to_sheets') summary.updated_in_sheets++;\n  if (d.sync_action === 'create' && d.sync_direction === 'sheets_to_airtable') summary.created_in_airtable++;\n  if (d.sync_action === 'update' && d.sync_direction === 'sheets_to_airtable') summary.updated_in_airtable++;\n  if (d.has_conflict) summary.conflicts_detected++;\n}\n\nreturn [{ json: summary }];"
      }
    },
