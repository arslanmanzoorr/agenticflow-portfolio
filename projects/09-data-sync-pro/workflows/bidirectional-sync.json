            "Total Processed": "={{ $json.total_processed }}",
            "Created in Sheets": "={{ $json.created_in_sheets }}",
            "Updated in Sheets": "={{ $json.updated_in_sheets }}",
            "Created in Airtable": "={{ $json.created_in_airtable }}",
            "Updated in Airtable": "={{ $json.updated_in_airtable }}",
            "Conflicts": "={{ $json.conflicts_detected }}",
            "Errors": "={{ $json.errors }}",
