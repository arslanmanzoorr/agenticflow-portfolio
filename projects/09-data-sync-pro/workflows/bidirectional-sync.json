      "id": "error-handler",
      "name": "Error Handler",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2140, 520],
      "parameters": {
        "jsCode": "const error = $input.first();\nconst errorDetails = {\n  workflow: 'Bidirectional Sync',\n  error_message: error.json.message || 'Unknown error',\n  error_node: error.json.node || 'Unknown',\n  timestamp: new Date().toISOString(),\n  stack_trace: error.json.stack || ''\n};\nreturn [{ json: errorDetails }];"
      }
    },
