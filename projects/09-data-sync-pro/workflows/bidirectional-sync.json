    {
      "id": "normalize-airtable",
      "name": "Normalize Airtable Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 200],
      "parameters": {
        "jsCode": "const items = $input.all();\nconst normalized = items.map(item => {\n  const fields = item.json.fields || item.json;\n  return {\n    json: {\n      sync_id: fields['Sync ID'] || fields.sync_id || '',\n      name: fields['Name'] || fields.name || '',\n      email: fields['Email'] || fields.email || '',\n      status: fields['Status'] || fields.status || '',\n      category: fields['Category'] || fields.category || '',\n      amount: parseFloat(fields['Amount'] || fields.amount || 0),\n      last_modified: fields['Last Modified'] || fields.last_modified || new Date().toISOString(),\n      source: 'airtable',\n      airtable_record_id: item.json.id || ''\n    }\n  };\n});\nreturn normalized;"
      }
    },
    {
      "id": "normalize-sheets",
      "name": "Normalize Sheets Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 420],
      "parameters": {
        "jsCode": "const items = $input.all();\nconst normalized = items.map((item, index) => {\n  const row = item.json;\n  return {\n    json: {\n      sync_id: row['Sync ID'] || row['sync_id'] || '',\n      name: row['Name'] || row['name'] || '',\n      email: row['Email'] || row['email'] || '',\n      status: row['Status'] || row['status'] || '',\n      category: row['Category'] || row['category'] || '',\n      amount: parseFloat(row['Amount'] || row['amount'] || 0),\n      last_modified: row['Last Modified'] || row['last_modified'] || new Date().toISOString(),\n      source: 'google_sheets',\n      sheet_row_number: index + 2\n    }\n  };\n});\nreturn normalized;"
      }
    },
    {
      "id": "merge-records",
      "name": "Merge & Compare Records",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2.1,
      "position": [940, 300],
      "parameters": {
        "mode": "combineBySql",
        "combineBySql": {
          "query": "SELECT\n  COALESCE(a.sync_id, b.sync_id) AS sync_id,\n  a.sync_id AS airtable_id,\n  b.sync_id AS sheets_id,\n  a.name AS at_name,\n  b.name AS gs_name,\n  a.email AS at_email,\n  b.email AS gs_email,\n  a.status AS at_status,\n  b.status AS gs_status,\n  a.category AS at_category,\n  b.category AS gs_category,\n  a.amount AS at_amount,\n  b.amount AS gs_amount,\n  a.last_modified AS at_modified,\n  b.last_modified AS gs_modified,\n  a.airtable_record_id,\n  b.sheet_row_number\nFROM input1 a\nFULL OUTER JOIN input2 b ON a.sync_id = b.sync_id"
        }
      }
    },
    {
      "id": "diff-logic",
      "name": "Diff Logic - Classify Changes",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1180, 300],
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const d = item.json;\n  let action = 'none';\n  let direction = 'none';\n  let hasConflict = false;\n\n  const existsInAirtable = !!d.airtable_id;\n  const existsInSheets = !!d.sheets_id;\n\n  if (existsInAirtable && !existsInSheets) {\n    action = 'create';\n    direction = 'airtable_to_sheets';\n  } else if (!existsInAirtable && existsInSheets) {\n    action = 'create';\n    direction = 'sheets_to_airtable';\n  } else if (existsInAirtable && existsInSheets) {\n    const fieldsChanged = (\n      d.at_name !== d.gs_name ||\n      d.at_email !== d.gs_email ||\n      d.at_status !== d.gs_status ||\n      d.at_category !== d.gs_category ||\n      d.at_amount !== d.gs_amount\n    );\n\n    if (fieldsChanged) {\n      const atTime = new Date(d.at_modified).getTime();\n      const gsTime = new Date(d.gs_modified).getTime();\n      const timeDiff = Math.abs(atTime - gsTime);\n\n      if (timeDiff < 60000) {\n        hasConflict = true;\n        action = 'conflict';\n        direction = 'both';\n      } else if (atTime > gsTime) {\n        action = 'update';\n        direction = 'airtable_to_sheets';\n      } else {\n        action = 'update';\n        direction = 'sheets_to_airtable';\n      }\n    }\n  }\n\n  if (action !== 'none') {\n    results.push({\n      json: {\n        ...d,\n        sync_action: action,\n        sync_direction: direction,\n        has_conflict: hasConflict,\n        processed_at: new Date().toISOString()\n      }\n    });\n  }\n}\n\nreturn results;"
      }
    },
    {
      "id": "route-actions",
      "name": "Route by Action Type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [1420, 300],
      "parameters": {
        "rules": {
          "rules": [
            {
              "outputKey": "to_sheets",
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.sync_direction }}",
                    "rightValue": "airtable_to_sheets",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              }
            },
            {
              "outputKey": "to_airtable",
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.sync_direction }}",
                    "rightValue": "sheets_to_airtable",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              }
            },
            {
              "outputKey": "conflict",
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.has_conflict }}",
                    "rightValue": true,
                    "operator": {
                      "type": "boolean",
                      "operation": "equals"
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    },
