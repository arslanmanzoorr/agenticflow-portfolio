# ──────────────────────────────────────────────
# ShopSync - Environment Variables
# ──────────────────────────────────────────────

# Shopify Configuration
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_KEY=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-01

# Airtable Configuration
AIRTABLE_API_KEY=patXXXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_ORDERS_TABLE_ID=tblXXXXXXXXXXXXXX
AIRTABLE_INVENTORY_TABLE_ID=tblXXXXXXXXXXXXXX
AIRTABLE_RETURNS_TABLE_ID=tblXXXXXXXXXXXXXX
AIRTABLE_CUSTOMERS_TABLE_ID=tblXXXXXXXXXXXXXX

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_ORDERS_CHANNEL_ID=C0XXXXXXXXX
SLACK_INVENTORY_CHANNEL_ID=C0XXXXXXXXX
SLACK_RETURNS_CHANNEL_ID=C0XXXXXXXXX

# SMTP / Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@yourdomain.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=ShopSync Notifications
SMTP_FROM_EMAIL=notifications@yourdomain.com

# n8n Configuration
N8N_HOST=https://your-n8n-instance.com
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com/webhook
N8N_ENCRYPTION_KEY=your-encryption-key

# Returns Policy Configuration
RETURNS_WINDOW_DAYS=30
RETURNS_ELIGIBLE_STATUSES=delivered,fulfilled
RETURNS_LABEL_API_URL=https://api.easypost.com/v2
RETURNS_LABEL_API_KEY=EZAK_xxxxxxxxxxxxxxxxxxxx

# Inventory Thresholds
LOW_STOCK_THRESHOLD=10
CRITICAL_STOCK_THRESHOLD=3
